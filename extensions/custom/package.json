{
	"name": "custom",
	"description": "Please enter a description for your extension",
	"icon": "extension",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-bundle"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "bundle",
		"path": {
			"app": "dist/app.js",
			"api": "dist/api.js"
		},
		"entries": [
			{
				"type": "hook",
				"name": "hook",
				"source": "src/hook/index.ts"
			},
			{
				"type": "endpoint",
				"name": "v1",
				"source": "src/v1/index.ts"
			}
		],
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate",
		"add": "directus-extension add"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.4",
		"@types/node": "^25.9.1",
		"@types/node-telegram-bot-api": "^0.64.15",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"decimal.js": "^10.6.0",
		"nanoid": "^5.1.11",
		"node-telegram-bot-api": "^1.1.0"
	}
}
